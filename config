# To change models, DON'T TOUCH THE INLINED VALUES IN THE cuiclaude FUNCTION!!!
# Instead, uncomment the lines below

# export CUI_DEFAULT_MODEL="<OVERRIDE_MODEL_ID>"             # Override the default Sonnet model
# export CUI_DEFAULT_HAIKU="<OVERRIDE_HAIKU_MODEL_ID>"       # Override the default Haiku model
# export CUI_AWS_REGION="<OVERRIDE_GOVCLOUD_REGION>"         # Override the default GovCloud region

cuiclaude() {
  # 1. Validation: Ensure the API Key exists before trying to run
  if [ -z "$CUI_BEDROCK_API_KEY" ]; then
    echo "Error: CUI_BEDROCK_API_KEY is not set."
    echo "Please run your authentication command or export the variable first."
    return 1
  fi

  # 2. Execution with Fallbacks
  # This 'wraps' the variables for the 'claude' process only.
  # Format: TARGET_VAR="${SOURCE_VAR:-fallback_value}"

  ANTHROPIC_MODEL="${CUI_DEFAULT_MODEL:-us-gov.anthropic.claude-sonnet-4-5-20250929-v1:0}" \
  ANTHROPIC_HAIKU_MODEL="${CUI_DEFAULT_HAIKU:-anthropic.claude-3-haiku-20240307-v1:0}" \
  AWS_REGION="${CUI_AWS_REGION:-us-gov-west-1}" \
  AWS_BEARER_TOKEN_BEDROCK="$CUI_BEDROCK_API_KEY" \
  CLAUDE_CODE_USE_BEDROCK=1 \
  claude "$@"
}

