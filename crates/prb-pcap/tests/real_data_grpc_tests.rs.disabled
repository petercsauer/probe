#[test]
fn test_full_pipeline_h2c_cleartext() {
    let capture_path = fixtures_dir().join("http2/http2-h2c.pcap");

    if !capture_path.exists() {
        panic!(
            "Fixture not found: {}. Run download step first.",
            capture_path.display()
        );
    }

    let mut adapter = PcapCaptureAdapter::new(capture_path, None);
    let events: Vec<_> = adapter.ingest().collect();

    assert!(
        !events.is_empty(),
        "Pipeline should produce events from h2c capture"
    );

    let ok_events: Vec<_> = events.iter().filter_map(|r| r.as_ref().ok()).collect();
    assert!(
        !ok_events.is_empty(),
        "Should decode h2c cleartext capture"
    );

    // h2c uses HTTP/2 over cleartext TCP
    let tcp_events: Vec<_> = ok_events
        .iter()
        .filter(|e| e.transport == TransportKind::TcpStream)
        .collect();

    assert!(
        !tcp_events.is_empty(),
        "h2c should produce TCP stream events"
    );

    let stats = adapter.stats();
    assert!(stats.packets_read > 0, "Should read packets");
    assert!(stats.tcp_streams >= 1, "Should reassemble TCP streams");
}

#[test]
fn test_full_pipeline_http2_tls() {
    let capture_path = fixtures_dir().join("http2/http2-16-ssl.pcapng");

    if !capture_path.exists() {
        panic!(
            "Fixture not found: {}. Run download step first.",
            capture_path.display()
        );
    }

    // Note: This capture includes embedded TLS keys in DSB blocks
    let mut adapter = PcapCaptureAdapter::new(capture_path, None);
    let events: Vec<_> = adapter.ingest().collect();

    assert!(
        !events.is_empty(),
        "Pipeline should produce events from TLS capture"
    );

    let ok_events: Vec<_> = events.iter().filter_map(|r| r.as_ref().ok()).collect();
    assert!(
        !ok_events.is_empty(),
        "Should process TLS capture (may not decrypt without keylog)"
    );

    let stats = adapter.stats();
    assert!(stats.packets_read > 0, "Should read packets");
}

#[test]
fn test_real_captures_no_panic() {
    // This test ensures all real captures can be processed without panicking,
    // even if decoding partially fails (e.g., mid-stream captures, missing keys)
    let captures = vec![
        "grpc/grpc_person_search_protobuf_with_image.pcapng",
        "grpc/grpc_hello2_1call_very_simple2_gzip_javacs.pcapng",
        "grpc/grpc_json_streamtest.pcapng",
        "http2/http2-h2c.pcap",
        "http2/http2-16-ssl.pcapng",
    ];

    for capture in captures {
        let capture_path = fixtures_dir().join(capture);

        if !capture_path.exists() {
            panic!(
                "Fixture not found: {}. Run download step first.",
                capture_path.display()
            );
        }

        // Should not panic, even if decode fails
        let mut adapter = PcapCaptureAdapter::new(capture_path.clone(), None);
        let events: Vec<_> = adapter.ingest().collect();

        // Basic sanity checks
        let stats = adapter.stats();
        assert!(
            stats.packets_read > 0,
            "Capture {} should have packets",
            capture
        );

        // Should produce some events (OK or Err is fine, just no panic)
        assert!(
            !events.is_empty(),
            "Capture {} should produce events",
            capture
        );
    }
}
