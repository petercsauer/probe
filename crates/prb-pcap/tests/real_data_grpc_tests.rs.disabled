//! Full pipeline integration tests with real gRPC/HTTP2 captures.
//!
//! These tests run complete end-to-end processing: PCAP read → normalize → TCP reassembly →
//! protocol detection → gRPC/HTTP2 decode → DebugEvents.

use prb_core::{CaptureAdapter, TransportKind};
use prb_pcap::PcapCaptureAdapter;
use std::path::PathBuf;

/// Helper to get the fixtures directory path.
fn fixtures_dir() -> PathBuf {
    PathBuf::from(env!("CARGO_MANIFEST_DIR"))
        .parent()
        .unwrap()
        .parent()
        .unwrap()
        .join("tests/fixtures/captures")
}

#[test]
fn test_full_pipeline_grpc_person_search() {
    let capture_path = fixtures_dir().join("grpc/grpc_person_search_protobuf_with_image.pcapng");

    if !capture_path.exists() {
        panic!(
            "Fixture not found: {}. Run download step first.",
            capture_path.display()
        );
    }

    // Process through full pipeline
    let mut adapter = PcapCaptureAdapter::new(capture_path, None);
    let events: Vec<_> = adapter.ingest().collect();

    // Should produce events
    assert!(
        !events.is_empty(),
        "Pipeline should produce events from person search capture"
    );

    // Count successful events
    let ok_events: Vec<_> = events.iter().filter_map(|r| r.as_ref().ok()).collect();
    assert!(
        !ok_events.is_empty(),
        "Should have at least some successful events"
    );

    // Look for gRPC-related events
    let grpc_events: Vec<_> = ok_events
        .iter()
        .filter(|e| e.protocol == "grpc" || e.protocol == "http2")
        .collect();

    if !grpc_events.is_empty() {
        // Verify gRPC events have expected fields
        for event in &grpc_events {
            assert!(
                event.src.port() > 0,
                "Event should have valid source port"
            );
            assert!(
                event.dst.port() > 0,
                "Event should have valid destination port"
            );
        }
    }

    // Check stats
    let stats = adapter.stats();
    assert!(
        stats.packets_read > 0,
        "Should have read packets from capture"
    );
}

