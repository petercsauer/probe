@pytest.fixture
def orchestrator(mock_state, mock_config, mock_notifier, mock_monitor, mock_signal_handler, tmp_path):
    """Create Orchestrator instance."""
    log_dir = tmp_path / "logs"
    log_dir.mkdir()
    return Orchestrator(
        state=mock_state,
        config=mock_config,
        notifier=mock_notifier,
        monitor=mock_monitor,
        signal_handler=mock_signal_handler,
        log_dir=log_dir,
        recovery_agent=None,
        pool=None,
        running_pids={},
    )


@pytest.fixture
def sample_segments():
    """Sample segments for testing."""
    return [
        Segment(num=1, slug="seg-1", title="Segment 1", wave=1, depends_on=[]),
        Segment(num=2, slug="seg-2", title="Segment 2", wave=1, depends_on=[]),
        Segment(num=3, slug="seg-3", title="Segment 3", wave=2, depends_on=[1]),
    ]


@pytest.fixture
def sample_meta():
    """Sample plan metadata."""
    return PlanMeta(title="Test Plan", goal="Test goal")


@pytest.mark.asyncio
async def test_orchestrator_run_basic(
    orchestrator, sample_segments, sample_meta, mock_state, mock_notifier, mock_monitor
):
    """Test basic orchestrator run with one wave."""
    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    # Mock helper functions
    _run_wave = AsyncMock(return_value=[(1, "pass"), (2, "pass")])
    _run_gate = AsyncMock(return_value=(True, ""))
    _pre_wave_health_check = AsyncMock(return_value=(True, []))
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Verify monitor started and stopped
    mock_monitor.start.assert_awaited_once()
    mock_monitor.stop.assert_awaited_once()

    # Verify notifications
    mock_notifier.started.assert_awaited_once_with("Test Plan", 3, 1)
    mock_notifier.finished.assert_awaited_once()

    # Verify wave was run
    _run_wave.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_filter_pending_segments(orchestrator, sample_segments, mock_state):
    """Test filtering of pending segments."""
    # Mock one segment as passed, one as pending
    async def get_segment_side_effect(num):
        if num == 1:
            return {"status": "pass", "attempts": 0}
        return {"status": "pending", "attempts": 0}

    mock_state.get_segment = AsyncMock(side_effect=get_segment_side_effect)

    pending = await orchestrator._filter_pending_segments(sample_segments[:2])

    assert len(pending) == 1
    assert pending[0].num == 2


@pytest.mark.asyncio
async def test_orchestrator_skip_completed_wave(
    orchestrator, sample_segments, sample_meta, mock_state, mock_notifier
):
    """Test that completed waves are skipped."""
    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    # Mock all segments as passed
    mock_state.get_segment = AsyncMock(return_value={"status": "pass", "attempts": 0})

    _run_wave = AsyncMock()
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Wave should not have been run
    _run_wave.assert_not_awaited()


@pytest.mark.asyncio
async def test_orchestrator_shutdown_signal(
    orchestrator, sample_segments, sample_meta, mock_signal_handler
):
    """Test that orchestrator stops on shutdown signal."""
    waves = {1: sample_segments[:2], 2: [sample_segments[2]]}
    log_dir = Path("/tmp/logs")

    # Mock shutdown after first wave
    call_count = 0

    def is_shutting_down_side_effect():
        nonlocal call_count
        call_count += 1
        return call_count > 1

    mock_signal_handler.is_shutting_down = Mock(side_effect=is_shutting_down_side_effect)

    _run_wave = AsyncMock(return_value=[(1, "pass")])
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 2, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Should only run wave 1
    assert _run_wave.await_count == 1


@pytest.mark.asyncio
async def test_orchestrator_preflight_failure(
    orchestrator, sample_segments, sample_meta, mock_config, mock_notifier
):
    """Test that preflight failure stops orchestration."""
    mock_config.enable_preflight_checks = True

    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock()
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock(return_value=(False, ["error1", "error2"]))
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Wave should not have been run
    _run_wave.assert_not_awaited()
    # Error notification should have been sent
    mock_notifier.error.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_recovery_success(
    orchestrator, sample_segments, sample_meta, mock_config, mock_state
):
    """Test successful recovery of cascade victims."""
    mock_config.recovery_enabled = True

    # Create mock recovery agent
    recovery_agent = AsyncMock()
    recovery_agent.check_workspace_health = AsyncMock(return_value=(True, []))
    recovery_agent.identify_cascade_victims = AsyncMock(return_value=[2])
    orchestrator.recovery_agent = recovery_agent

    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock(return_value=[(1, "pass"), (2, "blocked")])
    _run_recovery_wave = AsyncMock(return_value=[(2, "pass")])
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()

    # Mock segment data for circuit breaker check
    mock_state.get_segment = AsyncMock(return_value={"status": "blocked", "attempts": 1})

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Recovery should have been attempted
    recovery_agent.check_workspace_health.assert_awaited_once()
    recovery_agent.identify_cascade_victims.assert_awaited_once()
    _run_recovery_wave.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_recovery_circuit_breaker(
    orchestrator, sample_segments, sample_meta, mock_config, mock_state
):
    """Test that recovery circuit breaker filters victims."""
    mock_config.recovery_enabled = True
    mock_config.recovery_max_attempts = 2

    recovery_agent = AsyncMock()
    recovery_agent.check_workspace_health = AsyncMock(return_value=(True, []))
    recovery_agent.identify_cascade_victims = AsyncMock(return_value=[2])
    orchestrator.recovery_agent = recovery_agent

    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock(return_value=[(1, "pass"), (2, "blocked")])
    _run_recovery_wave = AsyncMock()
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()

    # Mock segment with attempts >= max_attempts
    mock_state.get_segment = AsyncMock(return_value={"status": "blocked", "attempts": 3})

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Recovery should NOT have been run (filtered by circuit breaker)
    _run_recovery_wave.assert_not_awaited()


@pytest.mark.asyncio
async def test_orchestrator_gate_check_pass(
    orchestrator, sample_segments, sample_meta, mock_config, mock_notifier, mock_state
):
    """Test gate check passing."""
    mock_config.gate_command = "pytest"
    mock_config.gate_required = True

    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock(return_value=[(1, "pass"), (2, "pass")])
    _run_gate = AsyncMock(return_value=(True, "All tests passed"))
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 1, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Gate should have been run
    _run_gate.assert_awaited_once()
    mock_notifier.gate_result.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_gate_check_fail(
    orchestrator, sample_segments, sample_meta, mock_config, mock_notifier
):
    """Test gate check failing stops orchestration."""
    mock_config.gate_command = "pytest"
    mock_config.gate_required = True

    waves = {1: sample_segments[:2], 2: [sample_segments[2]]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock(return_value=[(1, "pass"), (2, "pass")])
    _run_gate = AsyncMock(return_value=(False, "Tests failed"))
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 2, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Wave 1 should run, but wave 2 should not (gate failed)
    assert _run_wave.await_count == 1
    mock_notifier.error.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_cleanup(
    orchestrator, sample_segments, sample_meta, mock_state, mock_monitor, mock_notifier
):
    """Test cleanup is always called."""
    waves = {1: sample_segments[:2]}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock(side_effect=Exception("Test error"))
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    with pytest.raises(Exception, match="Test error"):
        await orchestrator.run(
            sample_segments, waves, 1, sample_meta, log_dir,
            _run_wave, _run_gate, _pre_wave_health_check,
            _wait_for_network, _run_recovery_wave
        )

    # Cleanup should still have been called
    mock_monitor.stop.assert_awaited_once()
    mock_state.close.assert_awaited_once()
    mock_notifier.finished.assert_awaited_once()


@pytest.mark.asyncio
async def test_orchestrator_cleanup_with_pool(orchestrator, sample_segments, sample_meta):
    """Test cleanup with worktree pool."""
    mock_pool = AsyncMock()
    mock_pool.cleanup = AsyncMock()
    orchestrator.pool = mock_pool

    waves = {}
    log_dir = Path("/tmp/logs")

    _run_wave = AsyncMock()
    _run_gate = AsyncMock()
    _pre_wave_health_check = AsyncMock()
    _wait_for_network = AsyncMock()
    _run_recovery_wave = AsyncMock()

    await orchestrator.run(
        sample_segments, waves, 0, sample_meta, log_dir,
        _run_wave, _run_gate, _pre_wave_health_check,
        _wait_for_network, _run_recovery_wave
    )

    # Pool cleanup should have been called
    mock_pool.cleanup.assert_awaited_once()
