    """Mock StateDB."""
    state = AsyncMock()
    state.get_segment = AsyncMock(return_value={"status": "pending", "attempts": 0})
    state.set_meta = AsyncMock()
    state.log_event = AsyncMock()
    state.progress = AsyncMock(return_value={"pass": 2, "failed": 1})
    state.close = AsyncMock()
    return state


