# =============================================================================
# Rust / Cargo
# =============================================================================

# Build output (workspace-wide)
/target

# Backup files generated by rustfmt
**/*.rs.bk

# Cargo mutation testing output
**/mutants.out*/

# Cargo.lock is COMMITTED — this is a binary/CLI crate, not a library.
# Reproducible builds require a committed lockfile.

# =============================================================================
# Network capture artifacts
# =============================================================================

# Raw capture dumps — keep test fixtures in testdata/ tracked, but ignore
# ad-hoc captures dropped in a captures/ or recordings/ directory.
captures/
recordings/
dumps/
*.pcap
*.pcapng
*.cap
*.pcap.gz
*.pcapng.gz

# TLS key log files (NEVER commit — contain session secrets)
*.keylog
*.sslkeylog
*.pms
ssl-keys.txt

# =============================================================================
# Database files
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# MCAP / binary data artifacts
# =============================================================================
# Large MCAP session dumps outside of testdata/
*.mcap

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
._*

# Spotlight index
.Spotlight-V100
.Trashes

# =============================================================================
# Editor / IDE
# =============================================================================

# VSCode (settings are checked in per-project preference; adjust as needed)
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# JetBrains / RustRover
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Editor backup files
*.bak
*.orig

# =============================================================================
# Environment / secrets
# =============================================================================
.env
.env.local
.env.*.local
secrets.toml

# =============================================================================
# Misc
# =============================================================================

# cargo-flamegraph / profiling output
flamegraph.svg
perf.data
perf.data.old

# cargo-llvm-cov coverage output
lcov.info
coverage/

# Criterion benchmark baselines are committed; raw output dirs are not
target/

# OS temp files
Thumbs.db

# Orchestration / runtime logs
logs/

# Python bytecode
__pycache__/

# Orchestration execution artifacts
**/*.db-wal
**/*.db-shm
**/orchestrator.lock
.claude/plans/*/logs/*.log
.claude/plans/*/state.db
.claude/worktrees/*/
**/*.profraw
**/*.profdata
